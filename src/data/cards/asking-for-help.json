{
  "category": "Asking for Help & Politeness",
  "cards": [
    { "bg": "Може ли да ми помогнете?", "en": "Can you help me?", "pronunciation": "MO-zhe li da mi po-MOG-ne-te", "example": "Извинете, може ли да ми помогнете?", "type": "phrase" },
    { "bg": "моля", "en": "please", "pronunciation": "MO-lya", "example": "Едно кафе, моля.", "type": "interjection" },
    { "bg": "благодаря", "en": "thank you", "pronunciation": "bla-go-da-RYA", "example": "Благодаря за помощта.", "type": "verb" },
    { "bg": "мерси", "en": "thanks (informal)", "pronunciation": "mer-SI", "example": "Мерси, много си мил.", "type": "interjection" },
