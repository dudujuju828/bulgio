---
import Layout from '../layouts/Layout.astro';
import { cards as flashcards, categories, types, groups, categoryGroups } from '../data/loader';
---

<Layout title="Bulgio - Learn Bulgarian">
  <main>
    <header>
      <h1>Bulgio</h1>
      <p class="subtitle">Learn Bulgarian, one card at a time</p>
    </header>

    <div class="filters">
      <div class="filter-section">
        <div class="filter-header">
          <span class="filter-label">Category</span>
          <input
            type="text"
            id="category-search"
            class="category-search"
            placeholder="Search categories..."
            autocomplete="off"
          />
        </div>
        <div class="filter-pills" id="group-filters">
          <button class="pill active" data-value="all" type="button">All</button>
          {groups.map(g => (
            <button class="pill group-pill" data-value={g} type="button">{g}</button>
          ))}
        </div>
        <div class="category-panel" id="category-panel">
          <div class="filter-pills" id="category-filters">
            {categories.map(cat => (
              <button class="pill category-pill" data-value={cat} type="button">{cat}</button>
            ))}
          </div>
        </div>
      </div>
      <div class="filter-row">
        <span class="filter-label">Type</span>
        <div class="filter-pills" id="type-filters">
          <button class="pill active" data-value="all" type="button">All</button>
          {types.map(t => (
            <button class="pill" data-value={t} type="button">{t}</button>
          ))}
        </div>
      </div>
    </div>

    <div class="controls">
      <button id="shuffle-btn" type="button" aria-label="Shuffle cards">Shuffle</button>
      <span id="progress">1 / {flashcards.length}</span>
      <div class="mode-toggle">
        <button id="mode-bg" class="mode-btn active" type="button">BG &rarr; EN</button>
        <button id="mode-en" class="mode-btn" type="button">EN &rarr; BG</button>
      </div>
    </div>

    <div id="card-container">
      <div id="flashcard" role="button" tabindex="0" aria-label="Click to flip card">
        <div class="card-inner">
          <div class="card-front">
            <img class="card-image" id="front-image" src="" alt="" />
            <span class="card-label">Bulgarian</span>
            <span class="card-text" id="front-text"></span>
            <span class="card-pronunciation" id="front-pronunciation"></span>
            <span class="card-meta" id="front-meta"></span>
          </div>
          <div class="card-back">
            <span class="card-label">English</span>
            <span class="card-text" id="back-text"></span>
            <span class="card-example" id="back-example"></span>
          </div>
        </div>
      </div>
    </div>

    <div id="empty-state" class="empty-state" style="display:none;">
      No cards match your filters.
    </div>

    <div class="nav-buttons">
      <button id="prev-btn" type="button" aria-label="Previous card">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        Prev
      </button>
      <button id="next-btn" type="button" aria-label="Next card">
        Next
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>

    <div class="keyboard-hint">
      Space to flip &middot; Arrow keys to navigate &middot; S to shuffle
    </div>
  </main>

  <script define:vars={{ flashcards, categoryGroups }}>
    const allCards = flashcards;
    let cards = [...allCards];
    let currentIndex = 0;
    let isFlipped = false;
    let mode = 'bg';
    let activeCategory = 'all';
    let activeGroup = 'all';
    let activeType = 'all';
    let searchQuery = '';

    const card = document.getElementById('flashcard');
    const cardContainer = document.getElementById('card-container');
    const emptyState = document.getElementById('empty-state');
    const frontText = document.getElementById('front-text');
    const backText = document.getElementById('back-text');
    const backExample = document.getElementById('back-example');
    const frontPronunciation = document.getElementById('front-pronunciation');
    const frontMeta = document.getElementById('front-meta');
    const frontImage = document.getElementById('front-image');
    const frontLabel = card.querySelector('.card-front .card-label');
    const backLabel = card.querySelector('.card-back .card-label');
    const progress = document.getElementById('progress');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const shuffleBtn = document.getElementById('shuffle-btn');
    const modeBg = document.getElementById('mode-bg');
    const modeEn = document.getElementById('mode-en');
    const groupFilters = document.getElementById('group-filters');
    const categoryFilters = document.getElementById('category-filters');
    const categoryPanel = document.getElementById('category-panel');
    const typeFilters = document.getElementById('type-filters');
    const categorySearch = document.getElementById('category-search');
    const categoryPills = categoryFilters.querySelectorAll('.category-pill');

    // Build a set of categories for the active group
    function getCategoriesForGroup(group) {
      if (group === 'all') return null;
      return new Set(categoryGroups[group] || []);
    }

    function updateCategoryPanel() {
      const query = searchQuery.toLowerCase();
      const groupCats = getCategoriesForGroup(activeGroup);
      let anyVisible = false;

      categoryPills.forEach(pill => {
        const cat = pill.dataset.value;
        const matchesGroup = !groupCats || groupCats.has(cat);
        const matchesSearch = !query || cat.toLowerCase().includes(query);
        const visible = matchesGroup && matchesSearch;
        pill.style.display = visible ? '' : 'none';
        if (visible) anyVisible = true;
      });

      // Show panel when a group is selected or search is active
      const showPanel = activeGroup !== 'all' || query.length > 0;
      categoryPanel.classList.toggle('open', showPanel && anyVisible);
    }

    function filterCards() {
      const groupCats = getCategoriesForGroup(activeGroup);

      cards = allCards.filter(c => {
        let catMatch;
        if (activeCategory !== 'all') {
          catMatch = c.category === activeCategory;
        } else if (groupCats) {
          catMatch = groupCats.has(c.category);
        } else {
          catMatch = true;
        }
        const typeMatch = activeType === 'all' || c.type === activeType;
        return catMatch && typeMatch;
      });
      currentIndex = 0;
      if (cards.length === 0) {
        cardContainer.style.display = 'none';
        emptyState.style.display = 'block';
      } else {
        cardContainer.style.display = 'block';
        emptyState.style.display = 'none';
        renderCard();
      }
    }

    function renderCard() {
      if (cards.length === 0) return;
      const c = cards[currentIndex];
      if (c.image) {
        frontImage.src = `/images/cards/${c.image}`;
        frontImage.alt = c.en;
        frontImage.style.display = 'block';
        card.classList.add('has-image');
      } else {
        frontImage.src = '';
        frontImage.alt = '';
        frontImage.style.display = 'none';
        card.classList.remove('has-image');
      }
      if (mode === 'bg') {
        frontText.textContent = c.bg;
        frontPronunciation.textContent = c.pronunciation;
        frontLabel.textContent = 'Bulgarian';
        backText.textContent = c.en;
        backLabel.textContent = 'English';
      } else {
        frontText.textContent = c.en;
        frontPronunciation.textContent = '';
        frontLabel.textContent = 'English';
        backText.textContent = c.bg;
        backLabel.textContent = 'Bulgarian';
      }
      frontMeta.textContent = `${c.category} · ${c.type}`;
      backExample.textContent = c.example;
      progress.textContent = `${currentIndex + 1} / ${cards.length}`;
      unflip();
    }

    function flip() {
      if (cards.length === 0) return;
      isFlipped = !isFlipped;
      card.classList.toggle('flipped', isFlipped);
    }

    function unflip() {
      isFlipped = false;
      card.classList.remove('flipped');
    }

    function next() {
      if (cards.length === 0) return;
      currentIndex = (currentIndex + 1) % cards.length;
      renderCard();
    }

    function prev() {
      if (cards.length === 0) return;
      currentIndex = (currentIndex - 1 + cards.length) % cards.length;
      renderCard();
    }

    function shuffle() {
      if (cards.length === 0) return;
      for (let i = cards.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [cards[i], cards[j]] = [cards[j], cards[i]];
      }
      currentIndex = 0;
      renderCard();
    }

    // Group filter clicks
    groupFilters.addEventListener('click', (e) => {
      const btn = e.target.closest('.pill');
      if (!btn) return;
      groupFilters.querySelectorAll('.pill').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeGroup = btn.dataset.value;
      activeCategory = 'all';
      // Clear any active category pill
      categoryPills.forEach(b => b.classList.remove('active'));
      searchQuery = '';
      categorySearch.value = '';
      updateCategoryPanel();
      filterCards();
    });

    // Category filter clicks
    categoryFilters.addEventListener('click', (e) => {
      const btn = e.target.closest('.pill');
      if (!btn) return;
      // Toggle: clicking active category deselects it
      if (btn.classList.contains('active')) {
        btn.classList.remove('active');
        activeCategory = 'all';
      } else {
        categoryPills.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeCategory = btn.dataset.value;
      }
      filterCards();
    });

    // Search input
    categorySearch.addEventListener('input', (e) => {
      searchQuery = e.target.value;
      activeCategory = 'all';
      categoryPills.forEach(b => b.classList.remove('active'));

      if (searchQuery.length > 0) {
        // When searching, deselect group and show all matching
        activeGroup = 'all';
        groupFilters.querySelectorAll('.pill').forEach(b => b.classList.remove('active'));
        groupFilters.querySelector('[data-value="all"]').classList.add('active');
      }

      updateCategoryPanel();
      filterCards();
    });

    // Prevent space/arrow keys from triggering card actions when search is focused
    categorySearch.addEventListener('keydown', (e) => {
      e.stopPropagation();
    });

    // Type filter clicks
    function setupFilterGroup(container, setActive) {
      container.addEventListener('click', (e) => {
        const btn = e.target.closest('.pill');
        if (!btn) return;
        container.querySelectorAll('.pill').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        setActive(btn.dataset.value);
        filterCards();
      });
    }

    setupFilterGroup(typeFilters, v => { activeType = v; });

    card.addEventListener('click', flip);
    nextBtn.addEventListener('click', next);
    prevBtn.addEventListener('click', prev);
    shuffleBtn.addEventListener('click', shuffle);

    modeBg.addEventListener('click', () => {
      mode = 'bg';
      modeBg.classList.add('active');
      modeEn.classList.remove('active');
      renderCard();
    });

    modeEn.addEventListener('click', () => {
      mode = 'en';
      modeEn.classList.add('active');
      modeBg.classList.remove('active');
      renderCard();
    });

    document.addEventListener('keydown', (e) => {
      if (document.activeElement === categorySearch) return;
      if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); flip(); }
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next();
      if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') prev();
      if (e.key === 's' || e.key === 'S') shuffle();
    });

    let touchStartX = 0;
    card.addEventListener('touchstart', (e) => { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
    card.addEventListener('touchend', (e) => {
      const diff = e.changedTouches[0].screenX - touchStartX;
      if (Math.abs(diff) > 50) {
        diff > 0 ? prev() : next();
      }
    });

    renderCard();
  </script>
</Layout>

<style>
  main {
    max-width: 600px;
    margin: 0 auto;
    padding: 2rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    min-height: 100dvh;
  }

  header {
    text-align: center;
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: #71717a;
    font-size: 0.95rem;
    margin-top: 0.25rem;
  }

  .filters {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .filter-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .filter-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .category-search {
    flex: 1;
    background: #1e1e2e;
    border: 1px solid #2e2e3e;
    color: #e4e4e7;
    padding: 0.35rem 0.7rem;
    border-radius: 0.5rem;
    font-size: 0.8rem;
    outline: none;
    transition: border-color 0.15s;
  }

  .category-search::placeholder {
    color: #52525b;
  }

  .category-search:focus {
    border-color: #22c55e;
  }

  .filter-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .filter-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #52525b;
    font-weight: 600;
    min-width: 60px;
  }

  .filter-pills {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .pill {
    background: #1e1e2e;
    border: 1px solid #2e2e3e;
    color: #71717a;
    padding: 0.25rem 0.6rem;
    border-radius: 1rem;
    cursor: pointer;
    font-size: 0.75rem;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    text-transform: capitalize;
  }

  .pill:hover {
    background: #2a2a3a;
    color: #a1a1aa;
  }

  .pill.active {
    background: #22c55e;
    border-color: #22c55e;
    color: #0f1117;
    font-weight: 600;
  }

  .group-pill {
    font-weight: 500;
  }

  .category-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.25s ease, padding 0.25s ease;
    background: #161622;
    border-radius: 0.6rem;
    padding: 0 0.6rem;
  }

  .category-panel.open {
    max-height: 300px;
    overflow-y: auto;
    padding: 0.6rem;
    border: 1px solid #2e2e3e;
  }

  .category-panel .filter-pills {
    gap: 0.3rem;
  }

  .category-pill {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    text-transform: none;
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  #shuffle-btn {
    background: #1e1e2e;
    border: 1px solid #2e2e3e;
    color: #a1a1aa;
    padding: 0.4rem 0.9rem;
    border-radius: 0.5rem;
    cursor: pointer;
    font-size: 0.85rem;
    transition: background 0.15s, color 0.15s;
  }

  #shuffle-btn:hover {
    background: #2a2a3a;
    color: #e4e4e7;
  }

  #progress {
    color: #71717a;
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
  }

  .mode-toggle {
    display: flex;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid #2e2e3e;
  }

  .mode-btn {
    background: #1e1e2e;
    border: none;
    color: #71717a;
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    font-size: 0.8rem;
    transition: background 0.15s, color 0.15s;
  }

  .mode-btn.active {
    background: #22c55e;
    color: #0f1117;
    font-weight: 600;
  }

  #card-container {
    width: 100%;
    perspective: 1000px;
  }

  #flashcard {
    width: 100%;
    height: 280px;
    cursor: pointer;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  .card-inner {
    width: 100%;
    height: 100%;
    position: relative;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }

  #flashcard.flipped .card-inner {
    transform: rotateY(180deg);
  }

  .card-front,
  .card-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    border-radius: 1rem;
    padding: 2rem;
    border: 1px solid #2e2e3e;
  }

  .card-front {
    background: linear-gradient(145deg, #1a1a2e, #16162a);
  }

  .card-back {
    background: linear-gradient(145deg, #0d2818, #0a1f14);
    border-color: #1a3a28;
    transform: rotateY(180deg);
  }

  .card-image {
    display: none;
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 0.75rem;
    border: 1px solid #2e2e3e;
    flex-shrink: 0;
  }

  #flashcard.has-image {
    height: 340px;
  }

  #flashcard.has-image .card-front {
    gap: 0.5rem;
    padding: 1.25rem 2rem;
  }

  #flashcard.has-image .card-text {
    font-size: 1.8rem;
  }

  .card-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #52525b;
    font-weight: 600;
  }

  .card-text {
    font-size: 2.2rem;
    font-weight: 600;
    text-align: center;
    line-height: 1.3;
  }

  .card-front .card-text {
    color: #e4e4e7;
  }

  .card-back .card-text {
    color: #4ade80;
  }

  .card-pronunciation {
    font-size: 0.95rem;
    color: #71717a;
    font-style: italic;
  }

  .card-meta {
    font-size: 0.7rem;
    color: #3f3f46;
    text-transform: capitalize;
  }

  .card-example {
    font-size: 0.85rem;
    color: #6b7280;
    font-style: italic;
    text-align: center;
    line-height: 1.4;
    border-top: 1px solid #1a3a28;
    padding-top: 0.6rem;
    margin-top: 0.25rem;
  }

  .empty-state {
    color: #52525b;
    font-size: 0.95rem;
    padding: 4rem 0;
  }

  .nav-buttons {
    display: flex;
    gap: 1rem;
    width: 100%;
  }

  .nav-buttons button {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    background: #1e1e2e;
    border: 1px solid #2e2e3e;
    color: #a1a1aa;
    padding: 0.75rem;
    border-radius: 0.75rem;
    cursor: pointer;
    font-size: 0.95rem;
    transition: background 0.15s, color 0.15s;
  }

  .nav-buttons button:hover {
    background: #2a2a3a;
    color: #e4e4e7;
  }

  .keyboard-hint {
    color: #3f3f46;
    font-size: 0.75rem;
    text-align: center;
  }

  @media (max-width: 480px) {
    .card-text {
      font-size: 1.6rem;
    }
    #flashcard {
      height: 240px;
    }
    #flashcard.has-image {
      height: 300px;
    }
    .card-image {
      width: 64px;
      height: 64px;
    }
    #flashcard.has-image .card-text {
      font-size: 1.4rem;
    }
  }
</style>
